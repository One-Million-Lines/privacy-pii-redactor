APP_ENV=development
HOST=0.0.0.0
PORT=8000

REDIS_URL=redis://localhost:6379/0
MAPPING_TTL_SECONDS=900

DEFAULT_LANGUAGE=en
MIN_CONFIDENCE_SCORE=0.65

ENABLE_SPACY=true
ENABLE_PRESIDIO=true
ENABLE_REGEX=true

# Leave blank to disable authentication
API_KEY=

LOG_LEVEL=INFO

# External LLM provider settings (for proxy mode)
LLM_PROVIDER_URL=
LLM_PROVIDER_API_KEY=
LLM_TIMEOUT_SECONDS=60
